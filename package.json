  "icon": "calender.png",
  "minAppVersion": "1.4.9",
  "commands": [],
  "devDependencies": {
    "@types/json2md": "^1.5.4",
    "@types/mailparser": "^3.4.4",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.5",
    "@types/utf8": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "npm run lint --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --list-different \"**/*.ts\"",
    "build": "enconvo dev",
    "dev": "enconvo dev --dev"
  },
  "dependencies": {
    "@enconvo/api": "link:../../enconvo.nodejs/enconvo_api",
    "javascript-time-ago": "^2.5.10",
    "json2md": "^1.13.0",
    "juice": "^9.1.0",
    "mailparser": "^3.7.1",
    "mime-types": "^2.1.35",
    "osascript-tag": "^0.1.2",
    "turndown": "^7.2.0",
    "utf8": "^3.0.0"
  }
