{
  "$schema": "https://enconvo.com/schemas/extension.json",
  "version": "0.0.132",
  "author": "Enconvo",
  "from": "store",
  "license": "MIT",
  "categories": [
    "Productivity"
  ],
  "type": "module",
  "name": "apple-apps-and-services",
